PORT=3000
SESSION_SECRET=change-me-to-a-long-random-string

# SMS Gateway for Android — cloud server credentials
# Get these by installing https://sms-gate.app on the phone with the SIM,
# enabling "Cloud Server" mode, then copying the generated username/password.
SMS_GATEWAY_USERNAME=
SMS_GATEWAY_PASSWORD=
SMS_GATEWAY_URL=https://api.sms-gate.app/3rdparty/v1

# Hard cap matching the SIM's daily allowance
DAILY_SMS_LIMIT=100
